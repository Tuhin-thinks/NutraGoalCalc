# Food catalogue and database paths
NVC_CATALOGUE_PATH=nutrition-values.json
NVC_DATABASE_PATH=nutragocalc.db

# CORS: comma-separated origins allowed to call the backend API
NVC_CORS_ORIGINS=http://localhost:5173

# LLM provider (leave unset or empty to disable recipe parsing)
# Supported values: "openai", "ollama"
NVC_LLM_PROVIDER=

# OpenAI configuration (required when NVC_LLM_PROVIDER=openai)
NVC_OPENAI_API_KEY=
NVC_OPENAI_MODEL=gpt-4o-mini

# Ollama configuration (used when NVC_LLM_PROVIDER=ollama)
NVC_OLLAMA_BASE_URL=http://localhost:11434
NVC_OLLAMA_MODEL=llama3.2
